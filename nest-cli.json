{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/main-services/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/main-services/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/main-services",
  "projects": {
    "loggin-services": {
      "type": "application",
      "root": "apps/loggin-services",
      "entryFile": "main",
      "sourceRoot": "apps/loggin-services/src",
      "compilerOptions": {
        "tsConfigPath": "apps/loggin-services/tsconfig.app.json"
      }
    },
    "main-services": {
      "type": "application",
      "root": "apps/main-services",
      "entryFile": "main",
      "sourceRoot": "apps/main-services/src",
      "compilerOptions": {
        "tsConfigPath": "apps/main-services/tsconfig.app.json"
      }
    },
    "rider-services": {
      "type": "application",
      "root": "apps/rider-services",
      "entryFile": "main",
      "sourceRoot": "apps/rider-services/src",
      "compilerOptions": {
        "tsConfigPath": "apps/rider-services/tsconfig.app.json"
      }
    }
  }
}