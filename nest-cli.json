{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "apps/Rider-Services/src",
  "compilerOptions": {
    "deleteOutDir": true,
    "webpack": true,
    "tsConfigPath": "apps/Rider-Services/tsconfig.app.json"
  },
  "monorepo": true,
  "root": "apps/Rider-Services",
  "projects": {
    "Rider-Services": {
      "type": "application",
      "root": "apps/Rider-Services",
      "entryFile": "main",
      "sourceRoot": "apps/Rider-Services/src",
      "compilerOptions": {
        "tsConfigPath": "apps/Rider-Services/tsconfig.app.json"
      }
    },
    "loggin-services": {
      "type": "application",
      "root": "apps/loggin-services",
      "entryFile": "main",
      "sourceRoot": "apps/loggin-services/src",
      "compilerOptions": {
        "tsConfigPath": "apps/loggin-services/tsconfig.app.json"
      }
    }
  }
}